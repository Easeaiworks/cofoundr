# =====================================================================
# Cofoundr — environment variables (template)
# =====================================================================
# Copy this file to .env.local and fill in. NEVER commit .env.local.
# In production, set these in the Vercel dashboard (Project → Settings → Environment Variables).
# =====================================================================

# --- Site --------------------------------------------------------------
# Canonical URL. cofoundr.ca for now; flip to cofoundr.com once acquired.
NEXT_PUBLIC_SITE_URL=https://cofoundr.ca
# Used for outbound emails and legal disclaimers.
NEXT_PUBLIC_SITE_NAME=Cofoundr

# --- Supabase ----------------------------------------------------------
# Get these from your Supabase project → Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5...
# Service role key — SERVER ONLY. Never expose to the browser.
# Used for admin tasks that must bypass RLS (e.g. provisioning a new tenant).
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5...

# --- Anthropic (Claude API) -------------------------------------------
# Get from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Default model used by the Cofoundr persona.
# Sonnet for most turns, Opus for strategic turns (overridden in code).
ANTHROPIC_MODEL_DEFAULT=claude-sonnet-4-6
ANTHROPIC_MODEL_STRATEGY=claude-opus-4-6
ANTHROPIC_MODEL_FAST=claude-haiku-4-5-20251001

# --- Voyage AI (embeddings, used by the kb_cache semantic cache) -----
# Get from https://dash.voyageai.com → API Keys
# Free tier covers ~200 million tokens, plenty for early beta.
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-3-large

# --- Replicate (image generation for logos and brand assets) ---------
# Get from https://replicate.com/account/api-tokens
# Default model: black-forest-labs/flux-schnell (~$0.003/image, ~3 sec).
REPLICATE_API_TOKEN=
REPLICATE_LOGO_MODEL=black-forest-labs/flux-schnell

# --- Stripe (placeholder — wired up in Week 11) -----------------------
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Resend (transactional email — placeholder, Week 5) --------------
RESEND_API_KEY=

# --- Logs / observability (placeholder) -------------------------------
SENTRY_DSN=
POSTHOG_KEY=
